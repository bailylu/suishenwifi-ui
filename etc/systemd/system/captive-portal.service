[Unit]
Description=Captive Portal (only when AP active)
After=NetworkManager.service
Wants=NetworkManager.service

[Service]
Type=simple
ExecStartPre=/opt/captive-portal/cp-setup.sh
ExecStart=/usr/bin/python3 /opt/captive-portal/portal.py
ExecStopPost=/opt/captive-portal/cp-teardown.sh
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
